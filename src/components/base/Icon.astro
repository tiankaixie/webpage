---
interface Props {
  name:
    | 'arrow-up'
    | 'contents'
    | 'draft'
    | 'external'
    | 'film'
    | 'github'
    | 'git-merge'
    | 'git-pull'
    | 'menu'
    | 'radio'
    | 'rss'
    | 'search'
    | 'x'
  class?: string
  id?: string
  size?: number | string
  title?: string
}

const { name, class: className = '', id, size = '1.2em', title } = Astro.props
---

<svg
  class={`inline-block shrink-0 ${className}`}
  {id}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.7"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {title && <title>{title}</title>}
  {
    name === 'search' && (
      <>
        <>
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-4-4" />
        </>
      </>
    )
  }
  {
    name === 'arrow-up' && (
      <>
        <>
          <path d="m6 10 6-6 6 6" />
          <path d="M12 4v16" />
        </>
      </>
    )
  }
  {
    name === 'contents' && (
      <>
        <>
          <path d="M9 6h11M9 12h11M9 18h11" />
          <path d="M4 6h.01M4 12h.01M4 18h.01" />
        </>
      </>
    )
  }
  {name === 'menu' && <path d="M4 7h16M4 12h16M4 17h16" />}
  {
    name === 'rss' && (
      <>
        <>
          <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none" />
          <path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" />
        </>
      </>
    )
  }
  {
    name === 'external' && (
      <>
        <>
          <path d="M14 5h5v5M19 5l-9 9" />
          <path d="M18 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5" />
        </>
      </>
    )
  }
  {
    name === 'film' && (
      <>
        <>
          <rect x="3" y="5" width="18" height="14" rx="1" />
          <path d="M7 5v14M17 5v14M3 9h4M17 9h4M3 15h4M17 15h4" />
        </>
      </>
    )
  }
  {
    name === 'radio' && (
      <>
        <>
          <rect x="3" y="7" width="18" height="13" rx="2" />
          <circle cx="15" cy="13.5" r="3" />
          <path d="m7 7 10-4M6 11h3M6 15h3" />
        </>
      </>
    )
  }
  {
    name === 'git-merge' && (
      <>
        <>
          <circle cx="7" cy="5" r="2" />
          <circle cx="17" cy="7" r="2" />
          <circle cx="7" cy="19" r="2" />
          <path d="M7 7v10M17 9c0 4-2 5-5 5H7" />
        </>
      </>
    )
  }
  {
    name === 'git-pull' && (
      <>
        <>
          <circle cx="6" cy="5" r="2" />
          <circle cx="18" cy="19" r="2" />
          <path d="M6 7v12M18 17V8a3 3 0 0 0-3-3h-3" />
          <path d="m14 3-2 2 2 2" />
        </>
      </>
    )
  }
  {
    name === 'draft' && (
      <>
        <>
          <path d="M6 3h9l3 3v15H6z" />
          <path d="M14 3v4h4M9 12h6M9 16h6" />
        </>
      </>
    )
  }
  {
    name === 'github' && (
      <path
        fill="currentColor"
        stroke="none"
        d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.87c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.64-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.82a9.5 9.5 0 0 1 2.5.34c1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.77c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"
      />
    )
  }
  {
    name === 'x' && (
      <path
        fill="currentColor"
        stroke="none"
        d="M4.7 3h4.42l3.6 5.2L17.2 3h2.1l-5.62 6.79L20 21h-4.42l-4.06-5.86L6.7 21H4.6l5.96-7.45L4.7 3Zm3.34 1.6 8.38 14.8h1.54L9.58 4.6H8.04Z"
      />
    )
  }
</svg>
