---
import Link from './Link.astro'
import Icon from './Icon.astro'
import { ensureTrailingSlash, getUrl } from '~/utils/common'

import type { InternalNav, SocialLink } from '~/types'

type Props =
  | {
      type: 'internal'
      item: InternalNav
      mergeOnMobile: boolean
      mobileItemType?: 'text' | 'icon'
    }
  | {
      type: 'social'
      item: SocialLink
      mergeOnMobile: boolean
      mobileItemType?: 'text' | 'icon'
    }

const { type, item, mergeOnMobile, mobileItemType } = Astro.props

const getIconName = (icon: string): 'draft' | 'github' | 'x' => {
  if (icon.includes('github')) return 'github'
  if (icon.includes('twitter')) return 'x'
  return 'draft'
}
---

{
  type === 'internal' &&
    (mergeOnMobile ? (
      !mobileItemType ? (
        <Link
          class="transition-opacity duration-300 ease-in-out max-md:hidden"
          href={getUrl(ensureTrailingSlash(item.path))}
          title={item.title}
          aria-current={
            Astro.url.pathname === getUrl(ensureTrailingSlash(item.path))
              ? 'page'
              : false
          }
        >
          {(item.displayMode === 'alwaysIcon' ||
            item.displayMode === 'iconHiddenOnMobile' ||
            item.displayMode === 'iconToTextOnMobile') && (
            <Icon name={getIconName(item.icon)} />
          )}
          {(item.displayMode === 'alwaysText' ||
            item.displayMode === 'textHiddenOnMobile' ||
            item.displayMode === 'textToIconOnMobile') && (
            <span>{item.text}</span>
          )}
        </Link>
      ) : mobileItemType === 'text' ? (
        (item.displayMode === 'alwaysText' ||
          item.displayMode === 'iconToTextOnMobile') && (
          <li class="block border-b border-[var(--c-scrollbar)] py-3 leading-6">
            <Link
              class="block transition-opacity duration-300 ease-in-out"
              href={getUrl(ensureTrailingSlash(item.path))}
              title={item.title}
              aria-current={
                Astro.url.pathname === getUrl(ensureTrailingSlash(item.path))
                  ? 'page'
                  : false
              }
            >
              <span>{item.text}</span>
            </Link>
          </li>
        )
      ) : (
        (item.displayMode === 'alwaysIcon' ||
          item.displayMode === 'textToIconOnMobile') && (
          <Link
            class="block transition-opacity duration-300 ease-in-out"
            href={getUrl(ensureTrailingSlash(item.path))}
            title={item.title}
            aria-current={
              Astro.url.pathname === getUrl(ensureTrailingSlash(item.path))
                ? 'page'
                : false
            }
          >
            <Icon name={getIconName(item.icon)} />
          </Link>
        )
      )
    ) : (
      <Link
        class={`${
          item.displayMode === 'iconHiddenOnMobile' ||
          item.displayMode === 'textHiddenOnMobile'
            ? 'max-md:hidden'
            : ''
        } transition-opacity duration-300 ease-in-out`}
        href={getUrl(ensureTrailingSlash(item.path))}
        title={item.title}
        aria-current={
          Astro.url.pathname === getUrl(ensureTrailingSlash(item.path))
            ? 'page'
            : false
        }
      >
        {(item.displayMode === 'alwaysText' ||
          item.displayMode === 'textHiddenOnMobile') && (
          <span>{item.text}</span>
        )}
        {(item.displayMode === 'alwaysIcon' ||
          item.displayMode === 'iconHiddenOnMobile') && (
          <Icon name={getIconName(item.icon)} />
        )}
        {item.displayMode === 'textToIconOnMobile' && (
          <>
            <span class="max-md:hidden">{item.text}</span>
            <Icon class="md:hidden" name={getIconName(item.icon)} />
          </>
        )}
        {item.displayMode === 'iconToTextOnMobile' && (
          <>
            <span class="md:hidden">{item.text}</span>
            <Icon class="max-md:hidden" name={getIconName(item.icon)} />
          </>
        )}
      </Link>
    ))
}
{
  type === 'social' &&
    (mergeOnMobile ? (
      !mobileItemType ? (
        <Link
          class="transition-opacity duration-300 ease-in-out max-md:hidden"
          href={item.link}
          title={item.title}
          external={true}
        >
          {(item.displayMode === 'alwaysIcon' ||
            item.displayMode === 'iconHiddenOnMobile' ||
            item.displayMode === 'iconToTextOnMobile') && (
            <Icon name={getIconName(item.icon)} />
          )}
          {(item.displayMode === 'alwaysText' ||
            item.displayMode === 'textHiddenOnMobile' ||
            item.displayMode === 'textToIconOnMobile') && (
            <span>{item.text}</span>
          )}
        </Link>
      ) : mobileItemType === 'text' ? (
        (item.displayMode === 'alwaysText' ||
          item.displayMode === 'iconToTextOnMobile') && (
          <li class="block border-b border-[var(--c-scrollbar)] py-3 leading-6">
            <Link
              class="block transition-opacity duration-300 ease-in-out"
              href={item.link}
              title={item.title}
              external={true}
            >
              <span>
                {item.text}
                <Icon
                  name="external"
                  class="mb-2 -mr-0.5 -ml-1 align-middle text-xs opacity-50"
                  title="External link"
                />
              </span>
            </Link>
          </li>
        )
      ) : (
        (item.displayMode === 'alwaysIcon' ||
          item.displayMode === 'textToIconOnMobile') && (
          <Link
            class="block transition-opacity duration-300 ease-in-out"
            href={item.link}
            title={item.title}
            external={true}
          >
            <Icon name={getIconName(item.icon)} />
          </Link>
        )
      )
    ) : (
      <Link
        class={`${
          item.displayMode === 'iconHiddenOnMobile' ||
          item.displayMode === 'textHiddenOnMobile'
            ? 'max-md:hidden'
            : ''
        } transition-opacity duration-300 ease-in-out`}
        href={item.link}
        title={item.title}
        external={true}
      >
        {(item.displayMode === 'alwaysText' ||
          item.displayMode === 'textHiddenOnMobile') && (
          <span>{item.text}</span>
        )}
        {(item.displayMode === 'alwaysIcon' ||
          item.displayMode === 'iconHiddenOnMobile') && (
          <Icon name={getIconName(item.icon)} />
        )}
        {item.displayMode === 'textToIconOnMobile' && (
          <>
            <span class="max-md:hidden">{item.text}</span>
            <Icon class="md:hidden" name={getIconName(item.icon)} />
          </>
        )}
        {item.displayMode === 'iconToTextOnMobile' && (
          <>
            <span class="md:hidden">{item.text}</span>
            <Icon class="max-md:hidden" name={getIconName(item.icon)} />
          </>
        )}
      </Link>
    ))
}
