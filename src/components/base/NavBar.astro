---
import ThemeSwitch from '~/components/widgets/ThemeSwitch.astro'
---

<header
  class="relative z-10 flex items-center justify-between border-b border-border p-4"
>
  <a
    href="/"
    class="text-lg font-bold tracking-[-0.02em] text-foreground no-underline transition-opacity hover:opacity-60"
    aria-label="Tiankai Xie — Home"
  >
    TIANKAI XIE
  </a>
  <nav class="flex items-center gap-4 font-mono text-sm" aria-label="Main menu">
    <a
      href="/blog"
      class="text-[var(--c-text-light)] no-underline transition-colors hover:text-foreground"
      aria-current={Astro.url.pathname.startsWith('/blog') ? 'page' : undefined}
    >
      BLOG
    </a>
    <div class="print:opacity-0">
      <ThemeSwitch />
    </div>
  </nav>
</header>
