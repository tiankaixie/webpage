---
interface Props {
  posts: {
    slug: string
    data: {
      title: string
      pubDate: Date | string
      description?: string
    }
  }[]
}

const { posts } = Astro.props
---

<ol class="m-0 list-none p-0">
  {
    posts.map((post, index) => (
      <li class="group m-0 border-b border-border p-0">
        <a
          href={`/blog/${post.slug}`}
          class="grid gap-4 py-6 text-foreground no-underline transition-opacity hover:opacity-60 sm:grid-cols-[2.5rem_minmax(0,1fr)_auto] sm:items-start"
        >
          <span class="font-mono text-xs text-muted-foreground">
            {String(index + 1).padStart(2, '0')}
          </span>

          <span class="min-w-0">
            <span class="block text-xl font-bold leading-tight tracking-[-0.025em] sm:text-2xl">
              {post.data.title}
            </span>
            {post.data.description && (
              <span class="mt-3 block max-w-2xl text-sm leading-relaxed text-muted-foreground">
                {post.data.description}
              </span>
            )}
          </span>

          <span class="flex items-center justify-between gap-6 font-mono text-[0.7rem] text-muted-foreground sm:justify-end sm:text-xs">
            <time datetime={new Date(post.data.pubDate).toISOString()}>
              {new Date(post.data.pubDate)
                .toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: '2-digit',
                  timeZone: 'UTC',
                })
                .toUpperCase()}
            </time>
            <span aria-hidden="true">↗</span>
          </span>
        </a>
      </li>
    ))
  }
</ol>
