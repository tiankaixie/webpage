<bg-particle
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 -z-10 print:hidden"
>
  <canvas class="h-full w-full opacity-50 dark:opacity-30"></canvas>
</bg-particle>

<script>
  interface ParticlePoint {
    x: number
    y: number
    vx: number
    vy: number
  }

  class BgParticleElement extends HTMLElement {
    #canvas: HTMLCanvasElement | null = null
    #context: CanvasRenderingContext2D | null = null
    #particles: ParticlePoint[] = []
    #animationFrame: number | null = null
    #lastFrame = 0
    #reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

    connectedCallback() {
      this.#canvas = this.querySelector('canvas')
      this.#context = this.#canvas?.getContext('2d') ?? null
      if (!this.#canvas || !this.#context) return

      this.#resize()
      window.addEventListener('resize', this.#resize)

      if (this.#reduceMotion.matches) {
        this.#draw(false)
      } else {
        this.#animationFrame = requestAnimationFrame(this.#animate)
      }
    }

    disconnectedCallback() {
      window.removeEventListener('resize', this.#resize)
      if (this.#animationFrame) cancelAnimationFrame(this.#animationFrame)
      this.#animationFrame = null
    }

    #resize = () => {
      if (!this.#canvas || !this.#context) return

      const dpr = Math.min(window.devicePixelRatio || 1, 2)
      const width = window.innerWidth
      const height = window.innerHeight
      this.#canvas.width = width * dpr
      this.#canvas.height = height * dpr
      this.#canvas.style.width = `${width}px`
      this.#canvas.style.height = `${height}px`
      this.#context.setTransform(dpr, 0, 0, dpr, 0, 0)

      const count = Math.max(28, Math.floor((width * height) / 14000))
      this.#particles = Array.from({ length: count }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
      }))
    }

    #draw = (move: boolean) => {
      if (!this.#canvas || !this.#context) return

      const width = this.#canvas.clientWidth
      const height = this.#canvas.clientHeight
      this.#context.clearRect(0, 0, width, height)

      for (const particle of this.#particles) {
        if (move) {
          particle.x = (particle.x + particle.vx + width) % width
          particle.y = (particle.y + particle.vy + height) % height
        }

        this.#context.fillStyle = 'rgb(105 105 105 / 0.45)'
        this.#context.beginPath()
        this.#context.arc(particle.x, particle.y, 1.2, 0, Math.PI * 2)
        this.#context.fill()

        for (const other of this.#particles) {
          const distance = Math.hypot(
            particle.x - other.x,
            particle.y - other.y
          )
          if (distance > 105) continue

          this.#context.strokeStyle = `rgb(105 105 105 / ${0.11 * (1 - distance / 105)})`
          this.#context.lineWidth = 0.6
          this.#context.beginPath()
          this.#context.moveTo(particle.x, particle.y)
          this.#context.lineTo(other.x, other.y)
          this.#context.stroke()
        }
      }
    }

    #animate = (time: number) => {
      if (time - this.#lastFrame >= 1000 / 30) {
        this.#lastFrame = time
        this.#draw(true)
      }
      this.#animationFrame = requestAnimationFrame(this.#animate)
    }
  }

  if (!customElements.get('bg-particle')) {
    customElements.define('bg-particle', BgParticleElement)
  }
</script>
